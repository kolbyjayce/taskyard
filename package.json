{
  "name": "taskyard",
  "version": "1.0.0-beta.2",
  "type": "module",
  "description": "Agent-first project management. Markdown files, git, and an MCP server.",
  "private": true,
  "workspaces": [
    "packages/cli",
    "packages/mcp-server",
    "packages/dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently -n \"mcp,dash\" -c \"blue,green\" \"npm run dev:start -w packages/mcp-server\" \"npm run dev -w packages/dashboard\"",
    "dev:build": "concurrently \"npm run dev -w packages/mcp-server\" \"npm run dev -w packages/dashboard\"",
    "test": "vitest run",
    "lint": "eslint packages/*/src",
    "typecheck": "tsc --build",
    "sync-versions": "node scripts/sync-versions.js",
    "check-publish": "node scripts/check-publish-ready.js",
    "publish": "./scripts/publish.sh"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
