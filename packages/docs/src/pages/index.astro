---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { CopyButton } from '../components/CopyButton';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const installCmd = 'npm install -g taskyard';
---

<BaseLayout
  title="taskyard"
  description="Agent-first task management. Markdown files and an MCP server. Nothing more."
>
  <div class="flex min-h-screen flex-col">
    <Header />

    <main class="flex-1">
      <!-- ─── HERO ─────────────────────────────────────────────────── -->
      <section class="relative overflow-hidden">
        <!-- Dot grid texture -->
        <div class="dot-grid absolute inset-0 opacity-100" aria-hidden="true"></div>

        <!-- Amber atmospheric glow -->
        <div class="amber-glow absolute inset-0" aria-hidden="true"></div>

        <!-- Extra bottom fade -->
        <div
          class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent"
          aria-hidden="true"
        ></div>

        <div class="relative mx-auto max-w-5xl px-4 pb-24 pt-20 sm:px-6 sm:pt-28 lg:pt-36">
          <!-- Version badge -->
          <div class="mb-8 opacity-0 animate-fade-in animate-delay-100"
            style="animation-fill-mode: forwards;">
            <span class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/8 px-3 py-1 text-xs font-mono text-primary/80">
              <span class="h-1.5 w-1.5 rounded-full bg-primary animate-glow-pulse"></span>
              v0.1 beta · now on npm
            </span>
          </div>

          <!-- Main headline -->
          <div class="mb-6 opacity-0 animate-slide-up animate-delay-200"
            style="animation-fill-mode: forwards;">
            <h1 class="font-display text-5xl font-extrabold leading-none tracking-tight text-foreground sm:text-7xl lg:text-8xl">
              task<span class="text-gradient-amber">yard</span>
            </h1>
            <p class="mt-4 font-display text-2xl font-bold text-foreground/70 sm:text-3xl">
              Agent-first tasks.
            </p>
          </div>

          <!-- Description -->
          <p class="mb-10 max-w-xl font-sans text-base leading-relaxed text-muted-foreground opacity-0 animate-slide-up animate-delay-300"
            style="animation-fill-mode: forwards;">
            Markdown files and an MCP server. No database. No cloud sync. No accounts.
            Your agent thinks — taskyard just stores and retrieves.
          </p>

          <!-- Install command -->
          <div class="mb-10 opacity-0 animate-slide-up animate-delay-400"
            style="animation-fill-mode: forwards;">
            <div class="flex w-full items-center gap-3 rounded-lg border border-border bg-card/80 px-4 py-3 font-mono text-sm shadow-lg backdrop-blur-sm sm:inline-flex sm:w-auto">
              <span class="select-none text-primary/50 shrink-0">$</span>
              <code class="min-w-0 truncate text-foreground/90">{installCmd}</code>
              <span class="ml-auto h-4 w-px shrink-0 bg-border sm:ml-2"></span>
              <CopyButton client:load text={installCmd} />
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap items-center gap-3 opacity-0 animate-slide-up animate-delay-500"
            style="animation-fill-mode: forwards;">
            <a
              href={`${base}/docs/`}
              class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-2.5 font-sans text-sm font-semibold text-primary-foreground shadow-[0_0_24px_rgba(245,158,11,0.25)] transition-all duration-200 hover:bg-primary/85 hover:shadow-[0_0_32px_rgba(245,158,11,0.4)]"
            >
              Get started
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="https://github.com/kolbyjayce/taskyard"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-border px-6 py-2.5 font-sans text-sm font-medium text-muted-foreground transition-all duration-200 hover:border-primary/40 hover:text-foreground"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              View on GitHub
            </a>
          </div>
        </div>
      </section>

      <!-- ─── FEATURES ───────────────────────────────────────────────── -->
      <section class="relative mx-auto max-w-5xl px-4 py-20 sm:px-6">
        <!-- Section label -->
        <p class="mb-10 font-mono text-xs font-semibold uppercase tracking-widest text-primary/60">
          Why taskyard
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <!-- Feature 1 -->
          <div class="group rounded-xl border border-border bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(245,158,11,0.06)]">
            <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg border border-primary/20 bg-primary/8">
              <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44l-1.006-6.027A2.5 2.5 0 0 1 8.5 10.5H9V7H6V5a3 3 0 0 1 3.5-2.958z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44l1.006-6.027A2.5 2.5 0 0 0 15.5 10.5H15V7h3V5a3 3 0 0 0-3.5-2.958z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-base font-bold text-foreground">MCP-native</h3>
            <p class="font-sans text-sm leading-relaxed text-muted-foreground">
              Built on the Model Context Protocol. Any MCP-compatible agent — Claude Code, OpenClaw, or your own — connects out of the box.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="group rounded-xl border border-border bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(245,158,11,0.06)]">
            <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg border border-primary/20 bg-primary/8">
              <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="16" y1="13" x2="8" y2="13" stroke-linecap="round"/>
                <line x1="16" y1="17" x2="8" y2="17" stroke-linecap="round"/>
                <line x1="10" y1="9" x2="8" y2="9" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-base font-bold text-foreground">Plain markdown</h3>
            <p class="font-sans text-sm leading-relaxed text-muted-foreground">
              Tasks are <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs text-primary">.md</code> files with YAML frontmatter. Read them with any text editor. Commit them to git. No lock-in.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="group rounded-xl border border-border bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(245,158,11,0.06)]">
            <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg border border-primary/20 bg-primary/8">
              <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-base font-bold text-foreground">Zero config</h3>
            <p class="font-sans text-sm leading-relaxed text-muted-foreground">
              Install globally, run <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs text-primary">taskyard start</code>. Tasks live at <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs text-primary">~/.taskyard/</code> by default. Override with <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs text-primary">--root</code> if needed.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="group rounded-xl border border-border bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(245,158,11,0.06)]">
            <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-lg border border-primary/20 bg-primary/8">
              <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M12 2L2 7l10 5 10-5-10-5z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 17l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-base font-bold text-foreground">Projects & contexts</h3>
            <p class="font-sans text-sm leading-relaxed text-muted-foreground">
              Organize tasks into named projects. Filter by status, priority, context, tag, or due date. Your agent gets exactly what it needs.
            </p>
          </div>
        </div>
      </section>

      <!-- ─── HOW IT WORKS ───────────────────────────────────────────── -->
      <section class="border-y border-border bg-card/40">
        <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
          <p class="mb-10 font-mono text-xs font-semibold uppercase tracking-widest text-primary/60">
            Up in 60 seconds
          </p>

          <div class="grid gap-8 sm:grid-cols-3">
            {[
              {
                step: '01',
                title: 'Install',
                code: 'npm install -g taskyard',
                description: 'Install the CLI globally from npm.',
              },
              {
                step: '02',
                title: 'Start',
                code: 'taskyard start',
                description: 'Run the MCP server. Tasks default to ~/.taskyard/.',
              },
              {
                step: '03',
                title: 'Connect',
                code: '"command": "taskyard"',
                description: 'Point your MCP client at the binary and start tasking.',
              },
            ].map(({ step, title, code, description }) => (
              <div class="relative">
                <div class="mb-3 font-mono text-4xl font-black text-primary/10 select-none">{step}</div>
                <h3 class="mb-2 font-display text-lg font-bold text-foreground">{title}</h3>
                <div class="mb-3 rounded-md border border-border bg-background/60 px-3 py-2 font-mono text-xs text-foreground/80">
                  {code}
                </div>
                <p class="font-sans text-sm text-muted-foreground">{description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ─── CTA ────────────────────────────────────────────────────── -->
      <section class="mx-auto max-w-5xl px-4 py-20 text-center sm:px-6">
        <h2 class="mb-4 font-display text-3xl font-bold text-foreground sm:text-4xl">
          Ready to give your agent a task list?
        </h2>
        <p class="mb-8 font-sans text-base text-muted-foreground">
          Read the docs and get running in minutes.
        </p>
        <a
          href={`${base}/docs/`}
          class="inline-flex items-center gap-2 rounded-md bg-primary px-8 py-3 font-sans text-sm font-semibold text-primary-foreground shadow-[0_0_30px_rgba(245,158,11,0.2)] transition-all duration-200 hover:bg-primary/85 hover:shadow-[0_0_40px_rgba(245,158,11,0.35)]"
        >
          Read the docs
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </section>
    </main>

    <!-- ─── FOOTER ─────────────────────────────────────────────────── -->
    <footer class="border-t border-border">
      <div class="mx-auto flex max-w-5xl flex-col items-start gap-3 px-4 py-6 sm:flex-row sm:items-center sm:justify-between sm:px-6">
        <div class="flex items-center gap-2 font-mono text-xs text-muted-foreground">
          <span class="h-1.5 w-1.5 rounded-full bg-primary/40"></span>
          <span>taskyard</span>
          <span class="text-border">·</span>
          <span>MIT License</span>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/kolbyjayce/taskyard"
            target="_blank"
            rel="noopener noreferrer"
            class="font-sans text-xs text-muted-foreground transition-colors hover:text-foreground"
          >
            GitHub
          </a>
          <a
            href={`${base}/docs/`}
            class="font-sans text-xs text-muted-foreground transition-colors hover:text-foreground"
          >
            Docs
          </a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
