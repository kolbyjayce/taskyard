{
  "name": "@taskyard/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for taskyard — atomic file ops, locking, git, watchdog",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "taskyard",
    "project-management",
    "ai-agents"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.22.0"
  }
}
