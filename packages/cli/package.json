{
  "name": "taskyard",
  "version": "1.0.0-beta.2-beta.20260320003457-beta.20260320023454",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolbyjayce/taskyard",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/kolbyjayce/taskyard#readme",
  "bugs": {
    "url": "https://github.com/kolbyjayce/taskyard/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "dashboard/**/*",
    "README.md"
  ],
  "description": "Agent-first project management CLI",
  "keywords": [
    "cli",
    "taskyard",
    "project-management",
    "ai-agents",
    "mcp",
    "git",
    "markdown"
  ],
  "bin": {
    "taskyard": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-dashboard",
    "copy-dashboard": "mkdir -p dashboard && cp -r ../dashboard/dist/* dashboard/ 2>/dev/null || echo 'Dashboard files not found, will be installed at runtime'",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@taskyard/mcp-server": "1.0.0-beta.2-beta.20260320003457-beta.20260320023454",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.0"
  }
}
