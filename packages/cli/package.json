{
  "name": "taskyard",
  "version": "1.0.0-alpha.20260320171934-alpha.20260320192033-beta.20260320194149",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolbyjayce/taskyard",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/kolbyjayce/taskyard#readme",
  "bugs": {
    "url": "https://github.com/kolbyjayce/taskyard/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "dashboard/**/*",
    "README.md"
  ],
  "description": "Agent-first project management CLI",
  "keywords": [
    "cli",
    "taskyard",
    "project-management",
    "ai-agents",
    "mcp",
    "git",
    "markdown"
  ],
  "bin": {
    "taskyard": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "npm run build:dashboard && tsc && npm run copy:dashboard",
    "build:dashboard": "cd ../dashboard && npm run build",
    "copy:dashboard": "rm -rf ./dashboard && cp -r ../dashboard/dist ./dashboard",
    "dev": "tsc --watch",
    "start": "node ./dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.22.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.4.0"
  }
}
