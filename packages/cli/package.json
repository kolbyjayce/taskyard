{
  "name": "taskyard",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolbyjayce/taskyard",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/kolbyjayce/taskyard#readme",
  "bugs": {
    "url": "https://github.com/kolbyjayce/taskyard/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "description": "Agent-first todo CLI — MCP server backed by markdown files",
  "keywords": [
    "cli",
    "taskyard",
    "todo",
    "ai-agents",
    "mcp",
    "markdown"
  ],
  "bin": {
    "taskyard": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.22.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
