{
  "name": "@taskyard/mcp-server",
  "version": "1.0.0-beta.2-beta.20260320003457-beta.20260320023454-alpha.20260320025558",
  "type": "module",
  "description": "MCP server for taskyard — atomic file ops, locking, git, watchdog",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolbyjayce/taskyard",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/kolbyjayce/taskyard#readme",
  "bugs": {
    "url": "https://github.com/kolbyjayce/taskyard/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "taskyard",
    "project-management",
    "ai-agents"
  ],
  "scripts": {
    "build": "tsc && npm run copy-dashboard",
    "copy-dashboard": "mkdir -p dist/dashboard && cp -r ../dashboard/dist/* dist/dashboard/ 2>/dev/null || echo 'Dashboard files not found, skipping copy'",
    "dev": "tsc --watch",
    "dev:start": "concurrently \"tsc --watch\" \"nodemon --watch dist dist/index.js --root . --http-port 3456\"",
    "start": "node dist/index.js",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
